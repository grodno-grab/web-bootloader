# URL of the JSON config: {"url":"...","urlSignatures":["...","..."],"contentSignatures":["...","..."]}
# The config file itself must be hosted at an immutable URL (see README for options).
VITE_CONFIG_URL=https://REPLACE_WITH_CONFIG_URL

# ML-DSA-65 public keys (base64-encoded, 1952 bytes each).
# Separate multiple keys with "|".
# Put real keys in .env.local (never commit secrets).
VITE_PUBLIC_KEYS=REPLACE_WITH_KEY_1|REPLACE_WITH_KEY_2
